#!/bin/bash

# Mihomo CLI Tool
# Usage: mihomocli <command>

API="http://127.0.0.1:9090"
MIHOMO_BIN="/opt/homebrew/opt/mihomo/bin/mihomo"
MIHOMO_DIR="/opt/homebrew/etc/mihomo"
MIHOMO_CONFIG="$MIHOMO_DIR/config.yaml"

# Check if ANY mihomo process is running (both user and root)
is_running() {
    pgrep -f "$MIHOMO_BIN" > /dev/null 2>&1
}

# Check if API is responding
is_api_ready() {
    curl -s --connect-timeout 1 "$API/proxies" > /dev/null 2>&1
}

# Get TUN enable status from API
get_tun_status() {
    curl -s "$API/configs" | jq -r '.tun.enable' 2>/dev/null || echo "false"
}

# Clean up residual utun interfaces
cleanup_tun() {
    for utun in $(ifconfig 2>/dev/null | grep '^utun' | cut -d: -f1); do
        sudo ifconfig "$utun" destroy 2>/dev/null || true
    done
}

# Wait for process to exit
wait_for_exit() {
    local max_wait=10
    local waited=0
    while is_running && [[ $waited -lt $max_wait ]]; do
        sleep 0.5
        ((waited+=1))
    done
    ! is_running
}

# Force kill ALL mihomo processes thoroughly
kill_all_mihomo() {
    # Try graceful kill first
    pkill -f "$MIHOMO_BIN" 2>/dev/null || true
    sudo pkill -f "$MIHOMO_BIN" 2>/dev/null || true
    sleep 1

    # If still running, force kill
    if is_running; then
        pkill -9 -f "$MIHOMO_BIN" 2>/dev/null || true
        sudo pkill -9 -f "$MIHOMO_BIN" 2>/dev/null || true
        sleep 0.5
    fi

    # Also try launchctl bootout
    sudo launchctl bootout gui/$(id -u)/homebrew.mxcl.mihomo 2>/dev/null || true

    wait_for_exit
}

stop_mihomo() {
    if ! is_running; then
        return 0
    fi

    # Stop via brew services
    sudo brew services stop mihomo 2>/dev/null
    sleep 1

    # Kill all remaining processes
    kill_all_mihomo

    # Cleanup TUN interfaces if any exist
    cleanup_tun
}

start_mihomo() {
    # Ensure clean state first
    if is_running; then
        kill_all_mihomo
    fi

    # Start via brew services
    sudo brew services start mihomo 2>/dev/null

    # Wait for API to be ready
    local max_wait=15
    local waited=0
    while ! is_api_ready && [[ $waited -lt $max_wait ]]; do
        sleep 0.5
        ((waited+=1))
    done

    is_api_ready
}

# Update TUN enable in config file precisely
update_tun_config() {
    local desired="$1"
    local config="$MIHOMO_CONFIG"

    if [[ ! -f "$config" ]]; then
        echo "Config file not found: $config" >&2
        return 1
    fi

    # Use awk to precisely target only tun.enable, not dns.enable
    awk -v desired="$desired" '
        /^tun:/ { in_tun = 1 }
        /^[^[:space:]]/ && !/^tun:/ { in_tun = 0 }
        in_tun && /^[[:space:]]*enable:/ {
            sub(/enable:[[:space:]]*(true|false)/, "enable: " desired)
        }
        { print }
    ' "$config" > "${config}.tmp" && mv "${config}.tmp" "$config"
}

show_status() {
    if ! is_running; then
        echo "Mihomo is not running, use 'mihomocli start' to start"
        return 1
    fi

    local node=$(curl -s "$API/proxies" | jq -r '.proxies.Proxy.now')
    local mode=$(curl -s "$API/configs" | jq -r '.mode')
    local tun=$(get_tun_status)
    local ip=$(curl -s --connect-timeout 2 https://ifconfig.me 2>/dev/null || echo 'N/A')

    local actual_node=$(curl -s "$API/proxies" | jq -r --arg n "$node" '.proxies[$n].now // $n')
    [[ -z "$actual_node" || "$actual_node" == "null" ]] && actual_node="$node"

    local group="$node"
    for g in 美国 日本 香港 新加坡 台湾 韩国; do
        local nodes=$(curl -s "$API/proxies" | jq -r --arg g "$g" '.proxies[$g].all[]' 2>/dev/null)
        if echo "$nodes" | grep -q "^${actual_node}$"; then
            group="$g"
            break
        fi
    done

    echo "=========================================="
    echo "  Current node: $actual_node"
    echo "  Node IP:   $ip"
    if [[ -n "$group" ]]; then
        echo ""
        echo "  === $group node latency ==="
        local nodes=$(curl -s "$API/proxies" | jq -r --arg g "$group" '.proxies[$g].all[]')
        for n in $nodes; do
            local delay=$(curl -s "$API/proxies/$n" 2>/dev/null | jq '[.extra."http://www.gstatic.com/generate_204".history[].delay] | map(select(. > 0)) | .[0]' 2>/dev/null)
            if [[ -n "$delay" && "$delay" != "null" ]]; then
                if [[ "$n" == "$actual_node" ]]; then
                    echo "  ★ $n: ${delay}ms"
                else
                    echo "    $n: ${delay}ms"
                fi
            fi
        done
    fi
    echo ""
    echo "  Mode: $mode | TUN: $([[ "$tun" == "true" ]] && echo "ON" || echo "OFF")"
    echo "=========================================="
}

show_latency() {
    if ! is_running; then
        echo "Mihomo is not running" >&2
        return 1
    fi

    local group="$1"
    local nodes=$(curl -s "$API/proxies" | jq -r --arg g "$group" '.proxies[$g].all[]')
    echo "=== $group node latency ==="
    for node in $nodes; do
        local delay=$(curl -s "$API/proxies/$node" 2>/dev/null | jq '[.extra."http://www.gstatic.com/generate_204".history[].delay] | map(select(. > 0)) | .[0]' 2>/dev/null)
        if [[ -n "$delay" && "$delay" != "null" ]]; then
            echo "$node: ${delay}ms"
        else
            echo "$node: N/A"
        fi
    done
    echo ""
    echo "Current: $(curl -s "$API/proxies" | jq -r --arg g "$group" '.proxies[$g].now')"
}

case "$1" in
    status)
        show_status
        ;;
    switch)
        if ! is_running; then
            echo "Mihomo is not running, please start it first"
            exit 1
        fi
        case "$2" in
            us)
                curl -s -X PUT "$API/proxies/Proxy" -d '{"name":"美国"}' -H "Content-Type: application/json"
                echo ""
                show_latency "美国"
                ;;
            jp)
                curl -s -X PUT "$API/proxies/Proxy" -d '{"name":"日本"}' -H "Content-Type: application/json"
                echo ""
                show_latency "日本"
                ;;
            auto)
                curl -s -X PUT "$API/proxies/Proxy" -d '{"name":"Auto"}' -H "Content-Type: application/json"
                echo "Switched to Auto"
                ;;
            *)
                echo "Usage: mihomocli switch <us|jp|auto>"
                ;;
        esac
        ;;
    latency)
        if ! is_running; then
            echo "Mihomo is not running"
            exit 1
        fi
        case "$2" in
            us)
                show_latency "美国"
                ;;
            jp)
                show_latency "日本"
                ;;
            all)
                show_latency "美国"
                show_latency "日本"
                ;;
            *)
                echo "Usage: mihomocli latency <us|jp|all>"
                ;;
        esac
        ;;
    mode)
        if ! is_running; then
            echo "Mihomo is not running"
            exit 1
        fi
        case "$2" in
            rule)
                curl -s -X PUT "$API/configs" -d '{"mode":"rule"}' -H "Content-Type: application/json"
                echo "Mode: rule"
                ;;
            global)
                curl -s -X PUT "$API/configs" -d '{"mode":"global"}' -H "Content-Type: application/json"
                echo "Mode: global"
                ;;
            direct)
                curl -s -X PUT "$API/configs" -d '{"mode":"direct"}' -H "Content-Type: application/json"
                echo "Mode: direct"
                ;;
            *)
                echo "Usage: mihomocli mode <rule|global|direct>"
                ;;
        esac
        ;;
    tun)
        if ! is_running; then
            echo "Mihomo is not running"
            exit 1
        fi
        case "$2" in
            on)
                update_tun_config "true"
                start_mihomo
                echo "TUN enabled, mihomo restarted"
                ;;
            off)
                update_tun_config "false"
                start_mihomo
                echo "TUN disabled, mihomo restarted"
                ;;
            *)
                echo "Usage: mihomocli tun <on|off>"
                ;;
        esac
        ;;
    node)
        if is_running; then
            curl -s "$API/proxies" | jq -r '.proxies.Proxy.now'
        else
            echo "Mihomo is not running"
        fi
        ;;
    start)
        if is_running; then
            echo "Mihomo is already running"
        else
            if start_mihomo; then
                echo "Mihomo has started"
                show_status
            else
                echo "Failed to start, please check logs"
            fi
        fi
        ;;
    stop)
        if is_running; then
            tun_status=$(get_tun_status)
            stop_mihomo
            if is_running; then
                echo "Failed to stop"
            else
                echo "Mihomo has stopped (TUN: $([[ "$tun_status" == "true" ]] && echo "ON" || echo "OFF"))"
            fi
        else
            echo "Mihomo is not running"
        fi
        ;;
    restart)
        stop_mihomo
        if start_mihomo; then
            echo "Mihomo has restarted"
            show_status
        else
            echo "Failed to restart, please check logs"
        fi
        ;;
    help|--help|-h|"")
        echo "Mihomo CLI Tool"
        echo ""
        echo "Usage: mihomocli <command>"
        echo ""
        echo "Commands:"
        echo "  status               Show current status (node, mode, TUN)"
        echo "  switch <us|jp|auto>  Switch proxy (URLTest auto selects)"
        echo "  latency <us|jp|all> Show latency for all nodes in group"
        echo "  mode <rule|global|direct>  Change mode"
        echo "  tun <on|off>        Enable/disable TUN"
        echo "  node                 Show current node"
        echo "  start                Start mihomo"
        echo "  stop                 Stop mihomo"
        echo "  restart              Restart mihomo"
        echo "  help                 Show this help message"
        ;;
esac